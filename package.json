{
  "name": "cedh-pox",
  "private": true,
  "version": "0.0.1",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently -n backend,frontend -c cyan,magenta \"bun run dev:backend\" \"bun run dev:frontend\"",
    "dev:backend": "bun run --cwd apps/backend dev",
    "dev:frontend": "bun run --cwd apps/frontend dev",
    "build": "bun run --cwd apps/frontend build",
    "deploy": "bun run --cwd apps/backend deploy"
  },
  "devDependencies": {
    "concurrently": "^10.0.3"
  }
}
